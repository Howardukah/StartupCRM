{
  "name": "ai-sprint-server",
  "version": "1.0.0",
  "description": "Local proxy server that securely calls the Groq API for AI-assisted sprint planning.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --forceExit tests/api",
    "test:stress": "node tests/stress/run_stress.js",
    "test:e2e": "playwright test tests/e2e"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "imapflow": "^1.4.3",
    "localtunnel": "^2.0.2",
    "mailparser": "^3.9.12",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "openai": "^4.52.0",
    "resend": "^6.18.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autocannon": "^8.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "playwright": "^1.61.1",
    "supertest": "^7.2.2"
  }
}
