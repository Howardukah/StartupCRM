# Groq AI Key
GROQ_API_KEY=your_groq_api_key_here

# Network Config
PORT=8787
CORS_ORIGIN=https://crm.startupbuild.tech,https://storage.startupbuild.tech

# Plan Files Storage Directory (Local fallback only)
PLANS_DIR=./PDF

# System-wide SMTP (Zoho Mail for welcome emails)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_USER=your-admin-email@yourdomain.com
SMTP_PASS=your-admin-app-password
SMTP_FROM_NAME=Startup CRM Admin
APP_URL=https://crm.startupbuild.tech

# Encryption Key (for user-specific Zoho credentials)
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_a_long_random_secret_string_at_least_32_chars

# Supabase Connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_secret_key

# Backblaze B2 Storage Connection (S3-compatible)
B2_KEY_ID=your_backblaze_key_id
B2_APP_KEY=your_backblaze_application_key
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_BUCKET_NAME=your-b2-bucket-name
